# ===========================
# CreditLens AI — Environment Variables
# ===========================

# MongoDB Atlas connection string
# Get this from: MongoDB Atlas → Database → Connect → Drivers → Connection String
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/creditlens?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=480

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Demo credentials (used to seed the first admin user)
DEMO_EMAIL=admin@idbi.co.in
DEMO_PASSWORD=CreditLens2026
